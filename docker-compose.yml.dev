services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "#unique_port#:8000"
    volumes:
      # Use Docker named volume for database persistence
      - app-data:/app/data
    # DATABASE_URL is set in Dockerfile as default; override here only if needed
    env_file:
      - .env.prod
    restart: unless-stopped
    container_name: #container_name#
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

# Define named volumes
volumes:
  app-data:
    driver: local
    name: #container_name#-data

